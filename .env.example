APP_NAME=Binance Spot Portfolio Tracker
ENVIRONMENT=development
LOG_LEVEL=INFO
API_PREFIX=/api

POSTGRES_USER=crypto_portfolio_user
POSTGRES_PASSWORD=crypto_portfolio
POSTGRES_DB=crypto_portfolio
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://crypto_portfolio_user:crypto_portfolio@localhost:5432/crypto_portfolio
BACKEND_PORT=8000

BINANCE_BASE_URL=https://api.binance.com
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_RECV_WINDOW_MS=5000
BINANCE_SYMBOLS=BTCUSDT,ETHUSDT
# Required before the first trade sync. Example: 2021-01-01T00:00:00Z = 1609459200000
# BINANCE_TRADE_SYNC_START_MS=1609459200000
PORTFOLIO_BASE_ASSET=USDT
