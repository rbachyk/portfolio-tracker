APP_NAME=Binance Spot Portfolio Tracker
ENVIRONMENT=development
LOG_LEVEL=INFO
API_PREFIX=/api

POSTGRES_USER=crypto_portfolio_user
POSTGRES_PASSWORD=crypto_portfolio
POSTGRES_DB=crypto_portfolio
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://crypto_portfolio_user:crypto_portfolio@localhost:5432/crypto_portfolio
BACKEND_PORT=8000
FRONTEND_PORT=3000

BINANCE_BASE_URL=https://api.binance.com
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_RECV_WINDOW_MS=5000
BINANCE_SYMBOLS=BTCUSDT,ETHUSDT
# Required before the first trade sync. Example: 2021-01-01T00:00:00Z = 1609459200000
# BINANCE_TRADE_SYNC_START_MS=1609459200000
# Required before wallet and Earn history backfills.
# BINANCE_HISTORY_SYNC_START_MS=1609459200000
PORTFOLIO_BASE_ASSET=USDT

DASHBOARD_USERNAME=admin
# Generate with:
# uv run --project backend python -c "from app.services.auth_service import hash_password; print(hash_password('replace-this-password'))"
DASHBOARD_PASSWORD_HASH=
# Generate with: openssl rand -hex 32
SESSION_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=720

INCLUDE_EARN_REWARDS_IN_PNL=true
COST_BASIS_METHOD=FIFO
PRICE_SYNC_INTERVAL_SECONDS=300
RECORDS_SYNC_INTERVAL_SECONDS=1800
SNAPSHOT_INTERVAL_SECONDS=3600
FULL_RECONCILIATION_INTERVAL_SECONDS=86400
WORKER_POLL_INTERVAL_SECONDS=15
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
